# ── LLM (Ollama Cloud — hosted API, no self-hosting needed) ──
OPENAI_API_KEY=your-ollama-cloud-api-key
OPENAI_BASE_URL=https://api.ollama.com/v1
LLM_PROVIDER=openai
LLM_MODEL=glm-4.7

# ── Web Search ──
TAVILY_API_KEY=tvly-your-tavily-key

# ── Clerk Auth ──
CLERK_PUBLISHABLE_KEY=pk_live_your-clerk-key
CLERK_SECRET_KEY=sk_live_your-clerk-key
CLERK_JWT_ISSUER=https://your-app.clerk.accounts.dev

# ── Database & Redis (overridden by docker-compose environment) ──
# DATABASE_URL=postgresql://nanobana:password@postgres:5432/nanobana
# REDIS_URL=redis://redis:6379/0

# ── Data Ingestion ──
WATCHLIST_TICKERS=AAPL,MSFT,TSLA,NVDA,GOOG,AMZN
INGESTION_CONCURRENCY=3

# ── CORS (comma-separated Vercel URLs) ──
CORS_ORIGINS=https://nanobana.vercel.app,https://your-custom-domain.com

# ── Logging ──
LOG_LEVEL=INFO
